#!/bin/sh
# Husky pre-push hook — full CI pipeline before pushing
# Skip in CI (GitHub Actions runs its own pipeline)
[ -n "$CI" ] && exit 0

echo "🏗️  Building for Cloudflare (OpenNext)..."
npm run pages:build || { echo "❌ Build failed!"; exit 1; }

echo "🎭 Running E2E tests (Playwright)..."
npx playwright test || { echo "❌ E2E tests failed!"; exit 1; }

echo "✅ All pre-push checks passed!"
