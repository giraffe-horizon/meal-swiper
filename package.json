{
  "name": "meal-swiper",
  "private": true,
  "version": "1.9.0",
  "author": "Giraffe Horizon <contact@giraffehorizon.com>",
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "cf:build": "opennextjs-cloudflare build",
    "cf:dev": "opennextjs-cloudflare build && wrangler dev",
    "deploy": "opennextjs-cloudflare build && wrangler deploy",
    "preview": "opennextjs-cloudflare build && wrangler dev",
    "lint": "eslint .",
    "type-check": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "test:e2e": "playwright test",
    "test:all": "vitest run --coverage && playwright test",
    "prepare": "husky",
    "pages:build": "opennextjs-cloudflare build && npx wrangler deploy --config wrangler.workers.toml --dry-run --outdir .open-next/wrangler-bundle && node scripts/wrap-worker-for-pages.mjs .open-next/wrangler-bundle/worker.js .open-next/assets/_worker.js && cp .open-next/wrangler-bundle/*.wasm .open-next/assets/ 2>/dev/null || true && echo \"_worker.js\" > .open-next/assets/.assetsignore",
    "release": "semantic-release"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.80.0",
    "@auth/d1-adapter": "^1.11.1",
    "@google/generative-ai": "^0.24.1",
    "@opennextjs/cloudflare": "^1.17.3",
    "@tanstack/react-query": "^5.95.2",
    "dotenv": "^17.3.1",
    "esbuild": "^0.27.4",
    "form-data": "^4.0.5",
    "framer-motion": "^12.38.0",
    "next": "16.2.1",
    "next-auth": "^4.24.13",
    "react": "^19.2.4",
    "react-dom": "^19.2.4"
  },
  "devDependencies": {
    "@eslint/compat": "^2.0.3",
    "@eslint/eslintrc": "^3.3.5",
    "@eslint/js": "^10.0.1",
    "@playwright/test": "^1.58.2",
    "@semantic-release/changelog": "^6.0.3",
    "@semantic-release/git": "^10.0.1",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/node": "25.5.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@typescript-eslint/eslint-plugin": "^8.57.2",
    "@typescript-eslint/parser": "^8.57.2",
    "@vitejs/plugin-react": "^5.1.4",
    "@vitest/coverage-v8": "^4.1.1",
    "autoprefixer": "^10.4.27",
    "eslint": "^10.1.0",
    "eslint-config-next": "^16.2.1",
    "husky": "^9.1.7",
    "jsdom": "^29.0.1",
    "lint-staged": "^16.4.0",
    "postcss": "^8.5.8",
    "prettier": "^3.8.1",
    "semantic-release": "^25.0.3",
    "tailwindcss": "^3.4.19",
    "typescript": "^5.9.3",
    "vitest": "^4.0.18",
    "wrangler": "^4.76.0"
  },
  "lint-staged": {
    "*.{ts,tsx,js,mjs,cjs}": [
      "prettier --write"
    ],
    "*.{json,css,md}": [
      "prettier --write"
    ]
  },
  "overrides": {
    "undici": ">=7.24.0"
  }
}
